---
import { getCollection } from 'astro:content';
import { ArrowDownRight } from '@lucide/astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../paths';
import { formatDate, SITE } from '../site';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.published.valueOf() - a.data.published.valueOf());
---

<BaseLayout immersive>
  <div class="home-stage">
    <aside class="home-rail" aria-label="文章轨道">
      <span class="rail-year">2026</span>
      <div class="rail-line" aria-hidden="true"></div>
      <div class="rail-dots">
        {posts.map((post, index) => (
          <button type="button" data-slide={index} title={post.data.title} aria-label={`跳到第 ${index + 1} 篇文章`}>
            <span>{String(index + 1).padStart(2, '0')}</span>
          </button>
        ))}
      </div>
      <span class="rail-count">{String(posts.length).padStart(2, '0')}</span>
    </aside>

    <div class="home-slides">
      {posts.map((post, index) => (
        <article class="story-slide" data-index={index} id={`story-${index + 1}`}>
          <img src={withBase(post.data.image)} alt={post.data.imageAlt} fetchpriority={index === 0 ? 'high' : 'auto'} />
          <span class="story-shade" aria-hidden="true"></span>
          <div class="story-topline">
            <span>{SITE.title}</span>
            <span>{post.data.tags[0]}</span>
          </div>
          <div class="story-copy">
            <p>{formatDate(post.data.published)} / No. {String(index + 1).padStart(2, '0')}</p>
            <h1>{post.data.title}</h1>
            <p class="story-description">{post.data.description}</p>
            <a href={withBase(`/posts/${post.id}/`)}>阅读全文 <ArrowDownRight size={20} /></a>
          </div>
        </article>
      ))}
    </div>
  </div>

  <section class="home-closing">
    <p>Journal / Notes / Observations</p>
    <h2>持续观察。<br />保持未完成。</h2>
    <a href={withBase('/posts/')}>进入全部文章 <ArrowDownRight size={20} /></a>
  </section>
</BaseLayout>

<script>
  const slides = [...document.querySelectorAll<HTMLElement>('.story-slide')];
  const dots = [...document.querySelectorAll<HTMLButtonElement>('.rail-dots button')];

  dots.forEach((dot, index) => {
    dot.addEventListener('click', () => slides[index]?.scrollIntoView({ behavior: 'smooth' }));
  });

  const observer = new IntersectionObserver((entries) => {
    const visible = entries
      .filter((entry) => entry.isIntersecting)
      .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
    if (!visible) return;
    const index = Number((visible.target as HTMLElement).dataset.index);
    dots.forEach((dot, dotIndex) => {
      dot.classList.toggle('is-active', dotIndex === index);
      if (dotIndex === index) dot.setAttribute('aria-current', 'true');
      else dot.removeAttribute('aria-current');
    });
  }, { threshold: [0.35, 0.6, 0.8] });

  slides.forEach((slide) => observer.observe(slide));
  dots[0]?.classList.add('is-active');
</script>
